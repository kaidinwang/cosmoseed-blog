---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const breadcrumb = [
  { name: '宇宙種子', url: 'https://cosmoseed.com.tw' },
  { name: '部落格', url: 'https://cosmoseed.com.tw/blog' },
];

const formatDate = (date: Date) =>
  date.toLocaleDateString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit' });
---

<BaseLayout
  title="部落格｜宇宙種子 CosmoSeed"
  description="宇宙種子部落格 — AEO、AI 工具、品牌行銷、AI 工作流的實戰筆記。從被 AI 搜尋引擎引用，到把硬核工具講成人話。"
>
  <Fragment slot="head">
    <BreadcrumbSchema items={breadcrumb} />
    <link rel="alternate" type="application/rss+xml" title="宇宙種子 Blog" href="/blog/rss.xml" />
  </Fragment>

  <section class="max-w-4xl mx-auto px-5 md:px-8 pt-12 md:pt-20 pb-10">
    <div class="pill mb-5">CosmoSeed · Blog</div>
    <h1 class="display-font text-4xl md:text-6xl font-bold leading-tight mb-5">
      被 <span class="bg-gradient-to-r from-[#60a5fa] to-[#a78bfa] bg-clip-text text-transparent">AI 引用</span><br />
      的品牌怎麼煉成
    </h1>
    <p class="text-lg md:text-xl text-[#475569] max-w-2xl leading-relaxed">
      AEO、AI 工具、品牌行銷、AI 工作流的實戰筆記。<br class="hidden md:block" />
      把硬核技術翻成人話，讓品牌在 AI 時代被看見。
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-5 md:px-8 pb-20">
    <div id="blogSearchStatus" class="hidden mb-6 text-sm text-[#475569]"></div>
    {posts.length === 0 ? (
      <div class="card p-10 text-center text-[#64748b]">
        部落格剛開張，第一篇文章準備中。
      </div>
    ) : (
      <div id="blogPostList" class="grid gap-5 md:gap-6">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id.replace(/\.md$/, '')}`}
            class="card p-7 md:p-9 group block hover:shadow-xl transition-shadow blog-post-card"
            data-title={post.data.title}
            data-description={post.data.description}
            data-category={post.data.category}
            data-tags={(post.data.tags ?? []).join(' ')}
          >
            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="pill">{post.data.category}</span>
              <time class="text-xs text-[#64748b]" datetime={post.data.publishDate.toISOString()}>
                {formatDate(post.data.publishDate)}
              </time>
            </div>
            <h2 class="display-font text-2xl md:text-3xl font-bold mb-3 leading-tight group-hover:text-[#4f46e5] transition-colors">
              {post.data.title}
            </h2>
            <p class="text-[#475569] leading-relaxed line-clamp-2 md:line-clamp-3">
              {post.data.description}
            </p>
            <div class="mt-5 text-sm text-[#4f46e5] font-medium">
              閱讀全文 →
            </div>
          </a>
        ))}
      </div>
    )}
    <div id="blogSearchEmpty" class="hidden card p-10 text-center text-[#64748b]">
      沒有符合的文章。試試其他關鍵字，或 <a href="/blog" class="text-[#4f46e5] underline">清除搜尋</a>。
    </div>
  </section>

  <script is:inline>
    (function () {
      const params = new URLSearchParams(window.location.search);
      const q = (params.get('q') || '').trim().toLowerCase();
      if (!q) return;
      const status = document.getElementById('blogSearchStatus');
      const empty = document.getElementById('blogSearchEmpty');
      const cards = document.querySelectorAll('.blog-post-card');
      let visible = 0;
      cards.forEach((card) => {
        const hay = [
          card.dataset.title || '',
          card.dataset.description || '',
          card.dataset.category || '',
          card.dataset.tags || '',
        ].join(' ').toLowerCase();
        const match = hay.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (status) {
        status.classList.remove('hidden');
        status.innerHTML = '搜尋「<strong>' + q.replace(/[<>&]/g, '') + '</strong>」結果 ' + visible + ' 篇 · <a href="/blog" class="text-[#4f46e5] underline">清除</a>';
      }
      if (empty && visible === 0) empty.classList.remove('hidden');
    })();
  </script>
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
