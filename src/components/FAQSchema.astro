---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faq: FAQItem[];
}

const { faq } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

{faq.length > 0 && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
