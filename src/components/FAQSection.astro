---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faq: FAQItem[];
}

const { faq } = Astro.props;
---

{
  faq.length > 0 && (
    <section class="mt-16 not-prose">
      <h2 class="display-font text-2xl md:text-3xl font-bold mb-6 relative pt-2">
        <span class="absolute top-0 left-0 w-10 h-[3px] rounded-full bg-gradient-to-r from-[#60a5fa] to-[#a78bfa]" />
        常見問題 FAQ
      </h2>
      <div class="space-y-3">
        {faq.map((item) => (
          <details class="card group p-5 cursor-pointer">
            <summary class="font-medium text-base md:text-lg list-none flex justify-between items-start gap-3">
              <span class="flex-1">{item.question}</span>
              <span class="text-[#a78bfa] transition-transform group-open:rotate-180 shrink-0">▾</span>
            </summary>
            <p class="mt-4 text-[#475569] leading-relaxed whitespace-pre-wrap">{item.answer}</p>
          </details>
        ))}
      </div>
    </section>
  )
}
