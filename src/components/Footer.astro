---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-[rgba(15,23,42,0.06)] bg-white/40 backdrop-blur-sm">
  <div class="max-w-5xl mx-auto px-5 md:px-8 py-10 text-sm text-[#64748b]">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <div class="display-font font-bold text-[#1e293b] text-base">宇宙種子 CosmoSeed</div>
        <p class="mt-1">把 AI 學好、用好，讓品牌被搜尋引擎與 AI 同時看見。</p>
      </div>
      <div class="flex gap-5">
        <a href="https://cosmoseed.com.tw" class="hover:text-[#4f46e5]">cosmoseed.com.tw</a>
        <a href="https://event.cosmoseed.com.tw" class="hover:text-[#4f46e5]">共學聚</a>
      </div>
    </div>
    <div class="mt-6 pt-6 border-t border-[rgba(15,23,42,0.05)] text-xs">
      © {year} 宇宙種子有限公司 CosmoSeed Co., Ltd. All rights reserved.
    </div>
  </div>
</footer>
